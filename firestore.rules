rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isParticipant() {
      return isAuthenticated() && request.auth.uid in resource.data.participants;
    }

    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isDoctor() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated(); // Needed to find users for messaging
      allow create: if isOwner(userId) && request.resource.data.role in ['mother', 'doctor', 'admin'];
      allow update: if isOwner(userId) && request.resource.data.role == resource.data.role; // Cannot change role
    }

    match /symptoms/{id} {
      allow read: if isDocOwner() || isDoctor();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    match /health_records/{id} {
      allow read: if isDocOwner() || isDoctor();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    match /appointments/{id} {
      allow read: if isDocOwner() || isDoctor();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isDocOwner();
    }

    match /messages/{id} {
      allow read: if isParticipant();
      allow create: if isAuthenticated() && 
        request.resource.data.senderId == request.auth.uid &&
        request.auth.uid in request.resource.data.participants;
    }

    match /ai_conversations/{id} {
      allow read, write: if isDocOwner();
    }
  }
}
